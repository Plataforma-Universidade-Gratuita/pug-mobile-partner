{
	"name": "pug-mobile-partner",
	"version": "1.0.0",
	"private": true,
	"main": "expo-router/entry",
	"scripts": {
		"dev": "cross-env NODE_OPTIONS=--use-system-ca expo start --offline --port 3002",
		"dev:mock": "cross-env NODE_OPTIONS=--use-system-ca node ./scripts/with-env.mjs mock-api.env expo start --offline --port 3002",
		"dev:tunnel": "cross-env NODE_OPTIONS=--use-system-ca expo start --tunnel --port 3002",
		"dev:tunnel:qa": "cross-env NODE_OPTIONS=--use-system-ca expo start --tunnel --port 3002",
		"dev:mock:tunnel": "cross-env NODE_OPTIONS=--use-system-ca node ./scripts/with-env.mjs mock-api.env expo start --tunnel --port 3002",
		"android": "cross-env NODE_OPTIONS=--use-system-ca expo start --offline --port 3002 --android",
		"android:mock": "cross-env NODE_OPTIONS=--use-system-ca node ./scripts/with-env.mjs mock-api.env expo start --offline --port 3002 --android",
		"ios": "cross-env NODE_OPTIONS=--use-system-ca expo start --offline --port 3002 --ios",
		"ios:mock": "cross-env NODE_OPTIONS=--use-system-ca node ./scripts/with-env.mjs mock-api.env expo start --offline --port 3002 --ios",
		"web": "cross-env NODE_OPTIONS=--use-system-ca expo start --offline --port 3002 --web",
		"web:mock": "cross-env NODE_OPTIONS=--use-system-ca node ./scripts/with-env.mjs mock-api.env expo start --offline --port 3002 --web",
		"trans": "node ./scripts/reorderTranslations.js dev && node ./scripts/checkMissingTranslations.js && node ./scripts/checkUnusedTranslations.js",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "npm run trans && prettier --write . && npm run lint:fix && tsc --noEmit",
		"format:check": "prettier --check . && npm run lint",
		"build:web": "cross-env NODE_OPTIONS=--use-system-ca expo export -p web",
		"verify": "npm run format:check && tsc --noEmit && npm run trans && npm run build:web"
	},
	"dependencies": {
		"@expo/config-plugins": "54.0.4",
		"@expo/vector-icons": "15.0.3",
		"@hookform/resolvers": "5.2.2",
		"@react-navigation/bottom-tabs": "7.15.11",
		"@react-navigation/elements": "2.9.25",
		"@react-navigation/native": "7.3.3",
		"@tanstack/react-query": "5.100.6",
		"clsx": "2.1.1",
		"date-fns": "4.1.0",
		"expo": "54.0.34",
		"expo-camera": "^57.0.0",
		"expo-constants": "18.0.13",
		"expo-font": "14.0.11",
		"expo-haptics": "15.0.8",
		"expo-image": "3.0.11",
		"expo-linking": "8.0.12",
		"expo-router": "6.0.23",
		"expo-secure-store": "15.0.8",
		"expo-splash-screen": "31.0.13",
		"expo-status-bar": "3.0.9",
		"expo-symbols": "1.0.8",
		"expo-system-ui": "6.0.9",
		"expo-web-browser": "15.0.11",
		"i18next": "26.0.8",
		"i18next-http-backend": "3.0.6",
		"jwt-decode": "4.0.0",
		"lucide-react-native": "0.542.0",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-hook-form": "7.74.0",
		"react-i18next": "17.0.6",
		"react-native": "0.81.5",
		"react-native-gesture-handler": "2.28.0",
		"react-native-paper": "^5.15.3",
		"react-native-reanimated": "4.1.1",
		"react-native-safe-area-context": "5.6.0",
		"react-native-screens": "4.16.0",
		"react-native-web": "0.21.0",
		"react-native-worklets": "0.5.1",
		"zod": "4.4.1",
		"zustand": "5.0.12"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3",
		"@expo/ngrok": "^4.1.3",
		"@trivago/prettier-plugin-sort-imports": "6.0.2",
		"@types/node": "25",
		"@types/react": "19.1.10",
		"cross-env": "^10.1.0",
		"eslint": "9.25.0",
		"eslint-config-expo": "10.0.0",
		"eslint-config-prettier": "10.1.8",
		"prettier": "3.8.3",
		"prettier-plugin-ini": "1.3.0",
		"prettier-plugin-packagejson": "3.0.2",
		"prettier-plugin-properties": "0.3.1",
		"prettier-plugin-tailwindcss": "0.8.0",
		"typescript": "5.9.3"
	}
}
